# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND - Variables de Entorno
# ═══════════════════════════════════════════════════════════════════════════════

# ── JWT & AUTENTICACIÓN ──────────────────────────────────────────────────────────
JWT_SECRET=tu_jwt_secret_super_seguro_aqui
JWT_EXPIRES_IN=7d

# ── SERVIDOR ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── FRONTEND (CORS y Redirecciones) ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── BASE DE DATOS ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=fwd_marketplace
DB_DIALECT=mysql

# ── GOOGLE OAUTH 2.0 ────────────────────────────────────────────────────────────
# Obtener credenciales en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tu_google_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── SESSION ──────────────────────────────────────────────────────────────────────
SESSION_SECRET=tu_session_secret_aqui

# ── AWS S3 (Opcional - para subir archivos) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=tu_aws_access_key
AWS_SECRET_ACCESS_KEY=tu_aws_secret_key
AWS_S3_BUCKET_NAME=tu_bucket_name
AWS_S3_REGION=us-east-1

# ── STRIPE (Opcional - para pagos) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=tu_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=tu_stripe_publishable_key

# ── EMAIL (Opcional - para notificaciones) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password
SMTP_FROM=noreply@fwdmarketplace.com
